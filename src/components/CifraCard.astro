---
const { title, description, label1, value1, label2, value2 } = Astro.props;
---

<div class="bg-tertiary/10 p-8 rounded-lg md:w-80">
    <h3 class="md:text-2xl text-lg  font-bold text-white md:mb-0 mb-4 text-center">
        {title}
    </h3>
    <p class="text-tertiary mt-4">
        {description}
    </p>
    <div class="mt-8 flex gap-8">
       <div>
            <p class="text-primary text-xl  text-uppercase text-center md:text-left">{value1}</p>
            <h3 class="text-xs text-white md:mb-0 mb-4 text-center md:text-left">{label1}</h3>
       </div>
         <div>
                <p class="text-primary text-xl text-uppercase text-center md:text-left">{value2}</p>
                <h3 class="text-xs text-white md:mb-0 mb-4 text-center md:text-left">{label2}</h3>
         </div>
    </div>
</div>

