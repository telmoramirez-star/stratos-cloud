---
const { title, description } = Astro.props;
---

<div class="p-8 rounded-lg shadow-lg text-center bg-gradient-to-bl from-primary/20 to-secondary/20 card-animation opacity-0">
  <h4 class="text-white md:text-2xl text-lg  font-bold">
    {title}
  </h4>
  <p class="text-tertiary mt-4 ">
    {description}
  </p>
</div>
