---
import SpecializationCard from "./SpecializationCard.astro";
---

<div class="py-32 px-8 max-w-5xl mx-auto">
  <div class="flex justify-between items-end">
    <div>
      <p class="text-primary text-sm text-uppercase">Ecosistema Cloud</p>
      <h3 class="text-white text-5xl font-bold">Soluciones Especializadas</h3>
    </div>
    <div>
      <p class="text-tertiary text-lg">
        Construimos, optimizamos y gestionamos entornos complejos para que tú te
        enfoques en innovar.
      </p>
    </div>
  </div>

  <div class="mt-8 grid grid-cols-3 gap-8">
    <SpecializationCard title="Desarrollo de Software Cloud Native" description="Arquitecturas modernas basadas en microservicios y contenedores para una agilidad empresarial sin precedentes." />
    <SpecializationCard title="Optimización de Costos AWS/Azure" description="Reducimos tu facturación mensual de nube mediante estrategias avanzadas de FinOps y dimensionamiento preciso." />
    <SpecializationCard title="Infraestructura como Código (IaC)" description="Automatización total mediante Terraform y Pulumi para despliegues repetibles, rápidos y libres de errores manuales." />
  </div>
</div>
