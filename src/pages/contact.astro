---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div class="px-8 py-32">
    <h1 class="text-white text-4xl md:text-8xl mb-6">
      Hablemos de <span class="text-primary">Infraestructura.</span>
    </h1>
    <p class="text-tertiary md:w-2/3">
      Estamos listos para escalar tu visión técnica con soluciones de nube de
      alto rendimiento. Ponte en contacto con nuestro equipo de ingeniería.
    </p>
  </div>
  <div class="px-8 pb-32 max-w-5xl mx-auto">
    <div class="grid md:grid-cols-3 gap-16">
      <div class="md:col-span-2">
        <form id="form-contact" class="grid md:grid-cols-2 gap-8 w-full">
          <div class="flex flex-col">
            <label for="name" class="text-white mb-2">Nombre Completo</label>
            <input
              type="text"
              id="name"
              placeholder="Ej. Alex Rivera"
              class="bg-dark text-tertiary placeholder:text-tertiary rounded-lg p-4 bg-neutral"
            />
          </div>
          <div class="flex flex-col">
            <label for="email" class="text-white mb-2">Correo Electrónico</label
            >
            <input
              type="email"
              id="email"
              placeholder="Ej. alex@rivera.com"
              class="bg-dark text-tertiary placeholder:text-tertiary rounded-lg p-4 bg-neutral"
            />
          </div>
          <div class="md:col-span-2 flex flex-col">
            <label for="subject" class="text-white mb-2">Asunto</label>
            <input
              type="text"
              id="subject"
              placeholder="Ej. Consulta sobre servicios"
              class="bg-dark text-tertiary placeholder:text-tertiary rounded-lg p-4 bg-neutral"
            />
          </div>
          <div class="md:col-span-2 flex flex-col">
            <label for="message" class="text-white mb-2">Mensaje</label>
            <textarea
              id="message"
              placeholder="Cuéntanos sobre tu proyecto..."
              class="bg-dark text-tertiary placeholder:text-tertiary rounded-lg p-4 bg-neutral"
            ></textarea>
          </div>
          <button
            type="submit"
            class="btn bg-primary text-primary-accent md:col-span-2"
            >Enviar Mensaje</button
          >
        </form>
      </div>
      <div>
        <div class="mb-6">
          <h2 class="text-lg text-white">Oficina Central</h2>
          <p class="text-tertiary">
            Torre Tecnológica Alpha, Nivel 42 Distrito de Innovación, San
            Salvador
          </p>
        </div>
        <div class="mb-6">
          <h2 class="text-lg text-white">Canales Directos</h2>
          <p class="text-tertiary">Soporte: support@stratoscloud.io</p>
          <p class="text-tertiary">Tel: +503 2200-4400</p>
        </div>
        <div>
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d127578.47562971432!2d-80.02494662268701!3d-2.2186729219510255!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x902d6dbf266d12ef%3A0x2a776d1e69594613!2sJos%C3%A9%20Joaqu%C3%ADn%20de%20Olmedo%20International%20Airport!5e0!3m2!1sen!2sec!4v1775360168614!5m2!1sen!2sec"
            height="250"
            width="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById("form-contact") as HTMLFormElement;
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const name = (document.getElementById("name") as HTMLInputElement).value;
      const email = (document.getElementById("email") as HTMLInputElement).value;
      const subject = (document.getElementById("subject") as HTMLInputElement).value;
      const message = (document.getElementById("message") as HTMLTextAreaElement).value;

      if (!name || !email || !subject || !message) {
        alert("Por favor, completa todos los campos.");
        return;
      }

      const btn = form.querySelector("button[type='submit']") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Enviando...";

      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, email, subject, message }),
      });

      const data = await res.json();

      if (res.ok) {
        alert("¡Mensaje enviado con éxito!");
        form.reset();
      } else {
        alert(data.error ?? "Ocurrió un error al enviar el mensaje.");
      }

      btn.disabled = false;
      btn.textContent = "Enviar Mensaje";
    });
  </script>
</Layout>
